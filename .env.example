# =========================================
# MARAMARA - Environment Variables Template
# =========================================
# Copy this file to .env and fill in secrets. DO NOT commit .env.

# ----- Environment -----
FLASK_ENV=development
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string

# ----- Supabase -----
SUPABASE_URL=https://tfygluotkrfjougyrvbw.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_REF=tfygluotkrfjougyrvbw

# ----- Database (direct Postgres access for migrations) -----
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.tfygluotkrfjougyrvbw.supabase.co:5432/postgres

# ----- Redis (for RQ job queue) -----
REDIS_URL=redis://localhost:6379/0

# ----- LLM / AI Keys -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ----- CrewAI -----
CREWAI_MODEL=claude-sonnet-4-6
CREWAI_TELEMETRY_OPT_OUT=true

# ----- ML Models Config -----
VAD_MODEL=silero
VAD_THRESHOLD=0.5
SPEAKER_MODEL=speechbrain/spkrec-ecapa-voxceleb
SPEAKER_SIMILARITY_THRESHOLD=0.75
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ----- Audio Config -----
AUDIO_CHUNK_DURATION_SEC=10
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
ENROLLMENT_MIN_DURATION_SEC=30
ENROLLMENT_MAX_DURATION_SEC=45

# ----- CORS / Frontend URLs -----
FRONTEND_URL=http://localhost:5000
MOBILE_DEEP_LINK_SCHEME=maramara

# ----- Feature Flags -----
RETAIN_RAW_AUDIO=false
ENABLE_REALTIME=true
ENABLE_CREWAI_INSIGHTS=true

# ----- Languages -----
SUPPORTED_LANGUAGES=he,en
DEFAULT_LANGUAGE=he
