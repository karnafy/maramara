# =========================================
# MARAMARA - Git Ignore
# =========================================

# ----- Secrets -----
.env
.env.local
.env.*.local
.supabase-db-password.txt
*.pem
*.key

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ----- Conda / Venv -----
venv/
env/
.venv/
ENV/

# ----- Node / Expo -----
node_modules/
.expo/
.expo-shared/
dist/
web-build/
*.log
*.log.err
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- OS -----
nul
Desktop.ini

# ----- Build artifacts -----
*.orig
*.rej
build/
out/

# ----- Docker -----
.docker/

# ----- Tests -----
.nyc_output/
coverage/

# ----- ML models (large files) -----
models/
*.pt
*.onnx
*.bin
whisper_models/
speechbrain_pretrained/

# ----- Audio artifacts (never commit) -----
*.wav
*.mp3
*.m4a
*.webm
audio_chunks/
recordings/

# ----- Tools folder (cloned reference repos - not our code) -----
tools/

# ----- Misc -----
*.tmp
.cache/
