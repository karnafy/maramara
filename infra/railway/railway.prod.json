{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "api/Dockerfile"
  },
  "deploy": {
    "numReplicas": 2,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "startCommand": "gunicorn --bind 0.0.0.0:$PORT --workers 4 --threads 4 --timeout 120 --access-logfile - app:app"
  },
  "environments": {
    "production": {
      "variables": {
        "APP_ENV": "production",
        "FLASK_ENV": "production",
        "DEBUG": "false",
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
